{
  "template_id": "collage_epic",
  "name": "Colagem Epica",
  "description": "Host + figuras AI do tema + cenário grandioso — para temas épicos, profecias",
  "canvas": { "width": 1280, "height": 720 },
  "layers": [
    {
      "id": "background",
      "type": "ai_generated",
      "z_index": 0,
      "generation": {
        "model": "flux_dev_q5",
        "resolution": [1024, 576],
        "upscale_to": [1280, 720],
        "steps": 20,
        "cfg": 1.0,
        "prompt_context": "epic wide shot, cinematic movie poster composition, dramatic sky, hyper detailed, 16:9"
      },
      "position": { "x": 0, "y": 0 },
      "size": { "w": 1280, "h": 720 },
      "effects": [
        { "type": "vignette", "intensity": 0.5 },
        { "type": "brightness", "value": -15 }
      ]
    },
    {
      "id": "figure_center",
      "type": "ai_generated",
      "z_index": 1,
      "optional": true,
      "generation": {
        "model": "flux_dev_q5",
        "resolution": [512, 768],
        "steps": 20,
        "cfg": 1.0,
        "prompt_context": "symbolic object, dramatic lighting, dark background, NO people, NO faces, NO bodies, NO human figures"
      },
      "position": { "x": 440, "y": 0 },
      "size": { "w": 400, "h": 500 },
      "effects": [
        { "type": "blend_mode", "mode": "screen" },
        { "type": "brightness", "value": -30 }
      ]
    },
    {
      "id": "figure_left",
      "type": "cutout_photo_or_ai",
      "z_index": 4,
      "position": { "x": -20, "y": 0 },
      "size": { "w": 550, "h": 720 },
      "effects": [
        { "type": "drop_shadow", "offset": [10, 5], "blur": 25, "color": [0, 0, 0, 220] },
        { "type": "rim_light", "color": "from_theme", "intensity": 0.4, "side": "right" }
      ]
    },
    {
      "id": "figure_right",
      "type": "cutout_photo_or_ai",
      "z_index": 3,
      "optional": true,
      "position": { "x": 850, "y": 50 },
      "size": { "w": 450, "h": 670 },
      "effects": [
        { "type": "desaturate", "amount": 0.3 },
        { "type": "drop_shadow", "offset": [-5, 5], "blur": 15, "color": [0, 0, 0, 180] }
      ]
    },
    {
      "id": "text_subtitle",
      "type": "text_rendered",
      "z_index": 10,
      "optional": true,
      "text_config": {
        "max_words": 6,
        "font_size_range": [28, 38],
        "color": "#FFFFFF",
        "font_weight": 700,
        "font_family": "from_brand",
        "stroke_width": 3,
        "stroke_color": "#000000",
        "letter_spacing": 3,
        "text_transform": "uppercase"
      },
      "position": { "x": 200, "y": 480 },
      "size": { "w": 880, "h": 60 }
    },
    {
      "id": "text_main",
      "type": "text_rendered",
      "z_index": 11,
      "text_config": {
        "max_words": 4,
        "font_size_range": [80, 120],
        "color": "from_brand.text.accent_text",
        "font_weight": 900,
        "font_family": "from_brand",
        "stroke_width": 6,
        "stroke_color": "#000000",
        "letter_spacing": 3
      },
      "position": { "x": 100, "y": 540 },
      "size": { "w": 1080, "h": 170 }
    },
    {
      "id": "border",
      "type": "shape",
      "z_index": 20,
      "shape": "rounded_rect_border",
      "color": "from_brand.style.border_color",
      "border_width": 6,
      "border_radius": 0,
      "position": { "x": 0, "y": 0 },
      "size": { "w": 1280, "h": 720 }
    }
  ]
}
